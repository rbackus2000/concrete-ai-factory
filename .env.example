DATABASE_URL="postgresql://postgres:postgres@localhost:5432/concrete_ai_factory?schema=public"
INTERNAL_AUTH_USERS_JSON='[{"username":"admin","password":"admin123","displayName":"Factory Admin","role":"ADMIN"},{"username":"operator","password":"operator123","displayName":"Factory Operator","role":"USER"}]'
GEMINI_API_KEY="your-google-ai-api-key"
GEMINI_IMAGE_MODEL="gemini-3-pro-image-preview"
GEMINI_IMAGE_ASPECT_RATIO="16:9"
GEMINI_IMAGE_SIZE="2K"

# MinIO bucket for product images on the VPS. When set, generated
# variants from fill-sku-color-palette.ts are pushed to the bucket
# in addition to being copied to the website's public/images dir.
# Leave blank to run local-only.
MINIO_ENDPOINT="https://cdn.opsrbstudio.com"
MINIO_BUCKET="bdc-products"
MINIO_ACCESS_KEY="rbstudio"
MINIO_SECRET_KEY="<minio-root-password>"

# Jacob — weekly market intelligence agent (Mondays 8 AM CT). The cron
# skips a run if the calendar-month spend exceeds this cap (USD).
INTEL_REPORT_MONTHLY_BUDGET_USD="25"

# Cron secret — Vercel sends Authorization: Bearer <CRON_SECRET> on cron
# invocations when this env var is set. Required in production.
CRON_SECRET="<long-random-string>"
