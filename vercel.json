{
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/dashboard/briefing/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/daily-briefing/route.ts": {
      "maxDuration": 120
    },
    "app/generator/page.tsx": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/price-sync",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/sequences",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/campaigns",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/triggers",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/daily-briefing",
      "schedule": "0 13 * * *"
    }
  ]
}
